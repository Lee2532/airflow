aws timezone 변경
sudo cp -p /usr/share/zoneinfo/Asia/Seoul /etc/localtime

및 도커파일과 yml tz 추가하여 체크중...
#dockerfile에 추가해봄
ENV TZ=Asia/Seoul
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone
 -> 됨!


